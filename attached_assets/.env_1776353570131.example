# =============================================================================
# M-PESA SCHOOL MANAGEMENT SAAS - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------
DEBUG=False
SECRET_KEY=your-super-secret-django-key-change-this-in-production
BASE_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/schoolsaas
# Or individual settings:
DB_NAME=schoolsaas
DB_USER=schoolsaas
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis Configuration (Celery + Cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Or individual settings:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# M-Pesa Configuration (Safaricom Daraja API)
# -----------------------------------------------------------------------------
# These are sandbox credentials - replace with live credentials for production
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=your-consumer-key-from-daraja
MPESA_CONSUMER_SECRET=your-consumer-secret-from-daraja
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey-from-daraja

# For B2C (Business to Customer) withdrawals
MPESA_SECURITY_CREDENTIAL=your-encrypted-security-credential
MPESA_INITIATOR_NAME=api

# -----------------------------------------------------------------------------
# Email Configuration (for notifications)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yoursaas.com

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-key-different-from-django-secret
JWT_ACCESS_TOKEN_LIFETIME=60  # minutes
JWT_REFRESH_TOKEN_LIFETIME=7  # days

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
ALLOWED_HOSTS=yourdomain.com,*.yourdomain.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# -----------------------------------------------------------------------------
# Sentry (Error Tracking) - Optional
# -----------------------------------------------------------------------------
SENTRY_DSN=your-sentry-dsn-url

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_FRAUD_DETECTION=True
ENABLE_COMPLIANCE_CHECKS=True
AUTO_SUSPEND_EXPIRED=True
ENABLE_EMAIL_NOTIFICATIONS=True

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_STK_PUSH=5  # per minute per user
RATE_LIMIT_API=100  # per minute per user

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE=10485760  # 10MB
FILE_UPLOAD_STORAGE=local  # or 's3' for AWS S3

# AWS S3 Settings (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
